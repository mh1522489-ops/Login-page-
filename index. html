<!DOCTYPE html>
<html>
<head>
    <title>Sarah's Portfolio | Login</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>

    <h1 id="card1">Welcome</h1>

    <section>
        <ul>
            <li>home</li>
            <li>portfolio</li>
            <li>targets</li>
            <li>design</li>
            <li>contact</li>
        </ul>
    </section>

    <section class="card2">
        <form id="card3">
            <fieldset id="wed">
                <h2>Account Login</h2>

                <input type="text" required placeholder="Email / Username" id="input1" autofocus>
                <input type="password" placeholder="Password" required>

                <button type="button">Sign In</button>

                <p class="forgot">Forgot your password?</p>

                <p class="signup-text">You don't have an account? <span class="signup-link">Sign Up</span></p>
            </fieldset>
        </form>
    </section>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-image: linear-gradient(to bottom right, yellow, pink);
            min-height: 100vh;
            font-family: Arial, Helvetica, sans-serif;
            padding: 20px;
        }

        /* Welcome title */
        #card1 {
            text-align: center;
            font-size: 50px;
            text-shadow: 1px 0px 2px black;
            margin-bottom: 30px;
        }

        /* Navbar */
        ul {
            display: flex;
            gap: 30px;
            list-style-type: none;
            height: 50px;
            background-color: black;
            color: white;
            align-items: center;
            border-radius: 50px;
            padding: 0 30px;
            margin-bottom: 40px;
            flex-wrap: wrap;
            justify-content: center;
        }

        ul li {
            transition: all 0.3s ease;
            padding: 8px 20px;
            border-radius: 25px;
            cursor: pointer;
        }

        ul li:hover {
            background-color: white;
            color: black;
            font-weight: bold;
            transform: scale(1.05);
        }

        /* Login card container */
        .card2 {
            background: linear-gradient(135deg, rgba(0,0,50,0.8), rgba(100,0,150,0.8));
            width: 100%;
            min-height: calc(100vh - 200px);
            border-radius: 50px;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px 20px;
        }

        /* Form style */
        #card3 {
            width: 100%;
            max-width: 450px;
        }

        h2 {
            color: white;
            text-align: center;
            margin-bottom: 25px;
            font-size: 28px;
        }

        #wed {
            border-radius: 25px;
            padding: 40px 30px;
            border: none;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(5px);
        }

        /* Inputs style */
        input {
            width: 100%;
            border: 2px solid rgba(255,255,255,0.5);
            background: rgba(255,255,255,0.9);
            outline: none;
            color: black;
            font-weight: bold;
            border-radius: 12px;
            margin: 10px 0;
            padding: 14px 18px;
            transition: all 0.3s ease;
            font-size: 16px;
        }

        /* Input hover effect - with rotate */
        input:hover {
            transform: rotate(1deg);
            background: black;
            color: white;
            border-color: gold;
        }

        /* Input focus effect */
        input:focus {
            border-color: gold;
            box-shadow: 0 0 12px rgba(255, 215, 0, 0.6);
            background: white;
            color: black;
            transform: scale(1.01);
        }

        /* Button style */
        button {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 40px;
            font-size: 20px;
            font-weight: bold;
            background: linear-gradient(90deg, gold, orange);
            color: black;
            margin: 20px 0 15px;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        button:hover {
            transform: scale(1.02);
            background: linear-gradient(90deg, orange, gold);
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
        }

        button:active {
            transform: scale(0.98);
        }

        /* Forgot password */
        .forgot {
            color: #ccc;
            text-align: center;
            text-decoration: underline;
            cursor: pointer;
            transition: all 0.3s ease;
            margin: 10px 0;
        }

        .forgot:hover {
            color: gold;
            transform: translateX(5px);
        }

        /* Sign up text */
        .signup-text {
            color: white;
            font-weight: bold;
            text-align: center;
            margin-top: 15px;
        }

        .signup-link {
            text-decoration: underline;
            cursor: pointer;
            transition: all 0.3s ease;
            color: gold;
        }

        .signup-link:hover {
            color: orange;
            transform: scale(1.05);
            display: inline-block;
        }

        /* Responsive */
        @media (max-width: 600px) {
            ul {
                gap: 10px;
            }
            ul li {
                padding: 5px 12px;
                font-size: 14px;
            }
            #card1 {
                font-size: 35px;
            }
            #wed {
                padding: 25px 20px;
            }
            h2 {
                font-size: 24px;
            }
            input, button {
                padding: 10px;
            }
        }
    </style>

</body>
</html>
